{
  "Version": "2012-10-17",
  "Statement": [
    { "Sid": "ScopedIamRoleMgmt", "Effect": "Allow",
      "Action": ["iam:CreateRole","iam:DeleteRole","iam:GetRole","iam:TagRole","iam:UntagRole","iam:AttachRolePolicy","iam:DetachRolePolicy","iam:PutRolePolicy","iam:DeleteRolePolicy","iam:GetRolePolicy","iam:ListRolePolicies","iam:ListAttachedRolePolicies","iam:UpdateAssumeRolePolicy"],
      "Resource": "arn:aws:iam::638515252275:role/jobhunt-*" },
    { "Sid": "ScopedPassRole", "Effect": "Allow", "Action": "iam:PassRole", "Resource": "arn:aws:iam::638515252275:role/jobhunt-*" },
    { "Sid": "ScopedPolicyMgmt", "Effect": "Allow",
      "Action": ["iam:CreatePolicy","iam:DeletePolicy","iam:GetPolicy","iam:GetPolicyVersion","iam:CreatePolicyVersion","iam:DeletePolicyVersion","iam:ListPolicyVersions"],
      "Resource": "arn:aws:iam::638515252275:policy/jobhunt-*" }
  ]
}
